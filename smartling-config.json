{
    "locales": [
        { "smartling": "en", "application": "en" }
    ],
    "resourceSets": [
        {
            "type": "javaProperties",
            "pathRegex": "messages/(?<name>.*)\\.properties",
            "translationPathExpression": "translations/${name}_${locale}.${originalFile.extension}",
            "translationCommitMessage": "Translate ${originalFile.name} to ${locale}",
            "authorizeContent": true
        }
    ]
}